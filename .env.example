# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/aichat

# JWT Secret
JWT_SECRET=your-secret-key

# Mobile App Security (optional but recommended)
# Set this to a random string and add to Expo app .env as EXPO_PUBLIC_MOBILE_API_KEY
# MOBILE_API_KEY=your-mobile-api-key-here

# Optional: For production
# API_KEY=your-api-key

# Firebase Cloud Messaging (FCM) for remote wake-up
FCM_SERVICE_ACCOUNT_KEY=./service-account-key.json

# FCM Wake-Up Script Configuration
# How often to scan for offline devices and send wake-up (cron format)
FCM_WAKE_UP_CRON=*/2 * * * * *

# How long a device must be offline before considering it for wake-up (seconds)
FCM_WAKE_UP_OFFLINE_THRESHOLD=120

# Maximum wake-up attempts per device per cycle before cooldown
FCM_WAKE_UP_MAX_ATTEMPTS=3

# Minimum minutes between wake-up attempts for the same device
FCM_WAKE_UP_COOLDOWN=5

# Legacy: Delay before auto-wake (deprecated, use FCM_WAKE_UP_OFFLINE_THRESHOLD)
# FCM_WAKE_UP_DELAY_SECONDS=300
