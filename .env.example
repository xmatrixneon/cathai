# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/aichat

# JWT Secret
JWT_SECRET=your-secret-key

# Mobile App Security (optional but recommended)
# Set this to a random string and add to Expo app .env as EXPO_PUBLIC_MOBILE_API_KEY
# MOBILE_API_KEY=your-mobile-api-key-here

# Optional: For production
# API_KEY=your-api-key
